---
layout: layouts/base.njk
i18n: de
permalink: /de/
title: ""
---

<!-- Hero -->
<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge-row">
        <span class="hero-badge badge-esphome">ESPHome</span>
        <span class="hero-badge badge-ha">Home Assistant</span>
        <span class="hero-badge badge-oss">Open Source · MIT</span>
      </div>
      <h1>FilaScale</h1>
      <p class="hero-subtitle">{{ i18n.hero.subtitle }}</p>
      <div class="hero-actions">
        <a href="{{ '/de/install/' | url }}" class="btn btn-primary btn-large">{{ i18n.hero.ctaInstall }}</a>
        <a href="{{ '/de/docs/' | url }}" class="btn btn-secondary btn-large">{{ i18n.hero.ctaDocs }}</a>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <svg class="hero-device-svg" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="40" y="140" width="120" height="14" rx="7" fill="#22d3ee" opacity=".9"/>
        <rect x="94" y="100" width="12" height="42" rx="4" fill="#22d3ee" opacity=".7"/>
        <rect x="30" y="88" width="140" height="16" rx="8" fill="#67e8f9" opacity=".85"/>
        <circle cx="100" cy="60" r="28" stroke="#22d3ee" stroke-width="3" fill="none" opacity=".6"/>
        <circle cx="100" cy="60" r="14" fill="#22d3ee" opacity=".25"/>
        <circle cx="100" cy="60" r="6" fill="#22d3ee" opacity=".6"/>
        <path d="M72 60 C72 44 128 44 128 60" stroke="#67e8f9" stroke-width="2" fill="none" opacity=".5"/>
        <path d="M148 72 C155 66 155 54 148 48" stroke="#818cf8" stroke-width="2.5" stroke-linecap="round" fill="none" opacity=".7"/>
        <path d="M156 78 C168 68 168 46 156 36" stroke="#818cf8" stroke-width="2" stroke-linecap="round" fill="none" opacity=".45"/>
        <path d="M164 83 C181 70 181 42 164 29" stroke="#818cf8" stroke-width="1.5" stroke-linecap="round" fill="none" opacity=".25"/>
        <rect x="62" y="146" width="76" height="4" rx="2" fill="#fff" opacity=".15"/>
      </svg>
    </div>
  </div>
</section>

<!-- Integrations strip -->
<div class="integrations">
  <div class="container">
    <div class="integrations-inner">
      <span class="integrations-label">{{ i18n.integrations.label }}</span>
      <div class="integration-badges">
        <span class="integration-badge"><span class="badge-icon">🏠</span> Home Assistant</span>
        <span class="integration-badge"><span class="badge-icon">🔌</span> ESPHome</span>
        <span class="integration-badge"><span class="badge-icon">🧵</span> Spoolman</span>
        <span class="integration-badge"><span class="badge-icon">🏷️</span> FilaMan</span>
        <span class="integration-badge"><span class="badge-icon">📡</span> OpenSpool</span>
        <span class="integration-badge"><span class="badge-icon">🐼</span> BambuLab RFID</span>
      </div>
    </div>
  </div>
</div>

<!-- Features -->
<section class="features section">
  <div class="container">
    <p class="section-label">{{ i18n.features.label }}</p>
    <h2 class="section-title">{{ i18n.features.title }}</h2>
    <p class="section-subtitle">{{ i18n.features.subtitle }}</p>
    <div class="features-grid">
      <div class="feature-card">
        <span class="feature-icon">⚖️</span>
        <h3>{{ i18n.features.weight.title }}</h3>
        <p>{{ i18n.features.weight.desc }}</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">📡</span>
        <h3>{{ i18n.features.nfc.title }}</h3>
        <p>{{ i18n.features.nfc.desc }}</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🏠</span>
        <h3>{{ i18n.features.ha.title }}</h3>
        <p>{{ i18n.features.ha.desc }}</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🖥️</span>
        <h3>{{ i18n.features.display.title }}</h3>
        <p>{{ i18n.features.display.desc }}</p>
      </div>
    </div>
  </div>
</section>

<!-- How it works -->
<section class="howto section">
  <div class="container">
    <p class="section-label">{{ i18n.howto.label }}</p>
    <h2 class="section-title">{{ i18n.howto.title }}</h2>
    <div class="howto-grid">
      {% for step in i18n.howto.steps %}
      <div class="howto-step">
        <div class="howto-num">{{ step.num }}</div>
        <h3>{{ step.title }}</h3>
        <p>{{ step.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Open Source -->
<section class="opensource section">
  <div class="container">
    <div class="opensource-inner">
      <div class="opensource-text">
        <p class="section-label">{{ i18n.opensource.label }}</p>
        <h2>{{ i18n.opensource.title }}</h2>
        <p>{{ i18n.opensource.desc }}</p>
        <div class="opensource-actions">
          <a href="https://github.com/ChristophCaina/FilaScale" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
            {{ i18n.opensource.btnGitHub }}
          </a>
          <a href="{{ '/de/docs/' | url }}" class="btn btn-secondary">{{ i18n.opensource.btnDocs }}</a>
        </div>
      </div>
      <div class="opensource-stats">
        <div class="stat-card"><div class="stat-icon">🔓</div><div class="stat-label">MIT Lizenz</div></div>
        <div class="stat-card"><div class="stat-icon">⚡</div><div class="stat-label">ESPHome</div></div>
        <div class="stat-card"><div class="stat-icon">📡</div><div class="stat-label">4 NFC Standards</div></div>
        <div class="stat-card"><div class="stat-icon">🖥️</div><div class="stat-label">2 Display-Typen</div></div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta section">
  <div class="container">
    <h2>{{ i18n.install.title }}</h2>
    <p>{{ i18n.install.subtitle }}</p>
    <a href="{{ '/de/install/' | url }}" class="btn btn-primary btn-large">{{ i18n.hero.ctaInstall }}</a>
  </div>
</section>


