---
layout: layouts/base.njk
i18n: de
permalink: /de/
title: ""
---

{% block content %}
<!-- Hero -->
<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge-row">
        <span class="hero-badge badge-esphome">ESPHome</span>
        <span class="hero-badge badge-ha">Home Assistant</span>
        <span class="hero-badge badge-oss">Open Source</span>
      </div>
      <h1>FilaScale</h1>
      <p class="hero-subtitle">{{ i18n.hero.subtitle }}</p>
      <div class="hero-actions">
        <a href="/de/install/" class="btn btn-primary btn-large">{{ i18n.hero.ctaInstall }}</a>
        <a href="/de/docs/" class="btn btn-secondary btn-large">{{ i18n.hero.ctaDocs }}</a>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <svg class="hero-device-svg" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Scale platform -->
        <rect x="40" y="140" width="120" height="14" rx="7" fill="#f97316" opacity=".9"/>
        <!-- Scale column -->
        <rect x="94" y="100" width="12" height="42" rx="4" fill="#f97316" opacity=".7"/>
        <!-- Scale tray -->
        <rect x="30" y="88" width="140" height="16" rx="8" fill="#fb923c" opacity=".85"/>
        <!-- Spool on tray (circle) -->
        <circle cx="100" cy="60" r="28" stroke="#f97316" stroke-width="3" fill="none" opacity=".6"/>
        <circle cx="100" cy="60" r="14" fill="#f97316" opacity=".25"/>
        <circle cx="100" cy="60" r="6" fill="#f97316" opacity=".6"/>
        <!-- Filament line around spool -->
        <path d="M72 60 C72 44 128 44 128 60" stroke="#fb923c" stroke-width="2" fill="none" opacity=".5"/>
        <!-- NFC waves -->
        <path d="M148 72 C155 66 155 54 148 48" stroke="#06b6d4" stroke-width="2.5" stroke-linecap="round" fill="none" opacity=".7"/>
        <path d="M156 78 C168 68 168 46 156 36" stroke="#06b6d4" stroke-width="2" stroke-linecap="round" fill="none" opacity=".45"/>
        <path d="M164 83 C181 70 181 42 164 29" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" fill="none" opacity=".25"/>
        <!-- Weight display on base -->
        <rect x="62" y="146" width="76" height="4" rx="2" fill="#fff" opacity=".15"/>
      </svg>
    </div>
  </div>
</section>

<!-- Integrations strip -->
<div class="integrations">
  <div class="container">
    <div class="integrations-inner">
      <span class="integrations-label">{{ i18n.integrations.label }}</span>
      <div class="integration-badges">
        <span class="integration-badge"><span class="badge-icon">🏠</span> Home Assistant</span>
        <span class="integration-badge"><span class="badge-icon">🔌</span> ESPHome</span>
        <span class="integration-badge"><span class="badge-icon">🧵</span> Spoolman</span>
        <span class="integration-badge"><span class="badge-icon">🏷️</span> FilaMan</span>
        <span class="integration-badge"><span class="badge-icon">📡</span> OpenSpool</span>
        <span class="integration-badge"><span class="badge-icon">🐼</span> BambuLab RFID</span>
      </div>
    </div>
  </div>
</div>

<!-- Features -->
<section class="features section">
  <div class="container">
    <p class="section-label">{{ i18n.features.label }}</p>
    <h2 class="section-title">{{ i18n.features.title }}</h2>
    <p class="section-subtitle">{{ i18n.features.subtitle }}</p>
    <div class="features-grid">
      <div class="feature-card">
        <span class="feature-icon">⚖️</span>
        <h3>{{ i18n.features.weight.title }}</h3>
        <p>{{ i18n.features.weight.desc }}</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">📡</span>
        <h3>{{ i18n.features.nfc.title }}</h3>
        <p>{{ i18n.features.nfc.desc }}</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🏠</span>
        <h3>{{ i18n.features.ha.title }}</h3>
        <p>{{ i18n.features.ha.desc }}</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🖥️</span>
        <h3>{{ i18n.features.display.title }}</h3>
        <p>{{ i18n.features.display.desc }}</p>
      </div>
    </div>
  </div>
</section>

<!-- Quick Install CTA -->
<section class="cta section">
  <div class="container">
    <h2>{{ i18n.install.title }}</h2>
    <p>{{ i18n.install.subtitle }}</p>
    <a href="/de/install/" class="btn btn-primary btn-large">{{ i18n.hero.ctaInstall }}</a>
  </div>
</section>
{% endblock %}
